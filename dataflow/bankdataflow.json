{
	"name": "bankdataflow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Storageaccount_ds",
						"type": "DatasetReference"
					},
					"name": "banksource"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "BronzeDS",
						"type": "DatasetReference"
					},
					"name": "bankfinalsink"
				},
				{
					"dataset": {
						"referenceName": "BronzeDS",
						"type": "DatasetReference"
					},
					"name": "fulluniondatasink"
				}
			],
			"transformations": [
				{
					"name": "Malefilter",
					"description": "Gender=\"Male\""
				},
				{
					"name": "selectdata"
				},
				{
					"name": "Femalefilter"
				},
				{
					"name": "MaleSalaryrank"
				},
				{
					"name": "FemaleSalaryrank"
				},
				{
					"name": "alldatarank"
				},
				{
					"name": "unionalldata"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerId as integer,",
				"          Surname as string,",
				"          CreditScore as short,",
				"          Geography as string,",
				"          Gender as string,",
				"          Age as short,",
				"          Tenure as short,",
				"          Balance as double,",
				"          NumOfProducts as short,",
				"          HasCrCard as boolean,",
				"          IsActiveMember as boolean,",
				"          EstimatedSalary as double,",
				"          Exited as boolean,",
				"          created_date as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: true,",
				"     inferDriftedColumnTypes: true,",
				"     limit: 100000,",
				"     ignoreNoFilesFound: false) ~> banksource",
				"selectdata filter(Gender==\"Male\") ~> Malefilter",
				"banksource select(skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectdata",
				"selectdata filter(Gender==\"Female\") ~> Femalefilter",
				"Malefilter rank(desc(CustomerId, true),",
				"     caseInsensitive: true,",
				"     output({MaleSalaryrank.EstimatedSalary} as long),",
				"     dense: true) ~> MaleSalaryrank",
				"Femalefilter rank(desc(CustomerId, true),",
				"     caseInsensitive: true,",
				"     output({FemaleSalaryrank.EstimatedSalary} as long),",
				"     dense: true) ~> FemaleSalaryrank",
				"selectdata rank(desc(CustomerId, true),",
				"     caseInsensitive: true,",
				"     output({alldatarank.EstimatedSalary} as long),",
				"     dense: true) ~> alldatarank",
				"MaleSalaryrank, FemaleSalaryrank union(byName: false)~> unionalldata",
				"alldatarank sink(allowSchemaDrift: true,",
				"     validateSchema: true,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> bankfinalsink",
				"unionalldata sink(allowSchemaDrift: true,",
				"     validateSchema: true,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> fulluniondatasink"
			]
		}
	}
}